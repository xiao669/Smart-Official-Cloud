# 药品管理系统 - 数据库备份配置文件
# 复制此文件为 .env 并修改配置

# ============ 数据库配置 ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=medicine_admin

# ============ 备份目录 ============
BACKUP_DIR=./backups

# ============ 备份保留策略 ============
# 保留7天的每日备份
KEEP_DAILY_DAYS=7
# 保留4周的每周备份  
KEEP_WEEKLY_WEEKS=4
# 保留12个月的每月备份
KEEP_MONTHLY_MONTHS=12

# ============ 邮件通知配置（可选）============
# 如果不需要邮件通知，留空即可
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_password
NOTIFY_EMAIL=admin@example.com

# ============ 阿里云OSS配置（可选）============
# 如果不需要云存储，设置为false
OSS_ENABLED=false
OSS_ACCESS_KEY=your_access_key
OSS_SECRET_KEY=your_secret_key
OSS_BUCKET=your_bucket_name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
